# ==============================================
# PRODUCTION CONFIGURATION EXAMPLE
# ==============================================
# Copy this file to .env and fill in your actual values

# Domain Configuration
DOMAIN=your-domain.com
FRONTEND_PORT=20001

# MySQL Configuration
MYSQL_ROOT_PASSWORD=your-strong-root-password
MYSQL_DATABASE=resto_order_hub
MYSQL_USER=resto_user
MYSQL_PASSWORD=your-strong-mysql-password

# Spring Boot Database Configuration
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/resto_order_hub?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=resto_user
SPRING_DATASOURCE_PASSWORD=your-strong-mysql-password
SPRING_JPA_HIBERNATE_DDL_AUTO=validate

# Flyway Configuration
FLYWAY_ENABLED=true
FLYWAY_CLEAN_ENABLED=false

# JWT Configuration
JWT_SECRET=your-256-bit-secret-key-for-jwt-token-signing-must-be-at-least-256-bits-long-for-security
JWT_ACCESS_TOKEN_EXPIRATION=900000
JWT_REFRESH_TOKEN_EXPIRATION=604800000

# CORS Configuration (Production Domain)
CORS_ALLOWED_ORIGINS=https://your-domain.com

# OAuth2 - Google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth2 - Facebook
FACEBOOK_CLIENT_ID=your-facebook-client-id
FACEBOOK_CLIENT_SECRET=your-facebook-client-secret

# OAuth2 Redirect URI (Production)
OAUTH2_REDIRECT_URI=https://your-domain.com/oauth2/redirect
OAUTH2_GOOGLE_REDIRECT_URI=https://your-domain.com/login/oauth2/code/google

# Email Configuration (Gmail SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# Server Configuration
SERVER_PORT=8080

# File Upload
FILE_UPLOAD_DIR=/app/uploads

# Frontend Configuration
NEXT_PUBLIC_API_URL=https://your-domain.com/api/v1
BACKEND_INTERNAL_URL=http://backend:8080
